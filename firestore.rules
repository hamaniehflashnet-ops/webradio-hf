rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: articles
    // Fields: title, content, imageUrl, category, authorId, createdAt, updatedAt
    //
    // Collection: podcasts
    // Fields: title, description, audioUrl, imageUrl, duration, createdAt
    //
    // Collection: pharmacies
    // Fields: name, phone, address, latitude, longitude, isOnDuty
    //
    // Collection: streams
    // Fields: type, url, currentShow, description
    //
    // Collection: users
    // Fields: displayName, email, role, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "hamaniehflashnet@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidArticle(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 &&
             data.imageUrl is string && data.imageUrl.size() > 0 &&
             data.category in ["actualité locale", "actualité internationale", "culture", "sport", "religion", "musique"];
    }

    function isValidPodcast(data) {
      return data.title is string && data.title.size() > 0 &&
             data.audioUrl is string && data.audioUrl.size() > 0;
    }

    function isValidPharmacy(data) {
      return data.name is string && data.name.size() > 0 &&
             data.phone is string && data.phone.size() > 0;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.adminCode == 'Domi@1986');
      allow delete: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /podcasts/{podcastId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pharmacies/{pharmacyId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /streams/{streamId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
